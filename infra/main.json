    "quakeStreamingFqdn": {
      "type": "string",
      "value": "[reference('quakeStreaming').outputs.fqdn.value]"
    },
    "storageAccountName": {
      "type": "string",
      "value": "[reference('storage').outputs.name.value]"
    },
    "keyVaultUri": {
      "type": "string",
      "value": "[reference('keyVault').outputs.uri.value]"
    }
  }
}