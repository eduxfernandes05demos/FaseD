                        {
                          "name": "QUAKE_MAP",
                          "value": "[parameters('quakeMap')]"
                        },
                        {
                          "name": "QUAKE_SKILL",
                          "value": "[parameters('quakeSkill')]"
                        },
                        {
                          "name": "QUAKE_MEM_MB",
                          "value": "64"
                        },
                        {
                          "name": "QUAKE_WIDTH",
                          "value": "640"
                        },
                        {
                          "name": "QUAKE_HEIGHT",
                          "value": "480"
                        },
                        {
                          "name": "APPLICATIONINSIGHTS_CONNECTION_STRING",
                          "value": "[format('InstrumentationKey={0}', parameters('appInsightsKey'))]"
                        },
                        {
                          "name": "STORAGE_ACCOUNT_NAME",
                          "value": "[parameters('storageAccountName')]"
                        },
                        {
                          "name": "AZURE_CLIENT_ID",
                          "value": "[parameters('userAssignedIdentityClientId')]"
                        }
                      ]
                    }
                  ],
                  "scale": {
                    "minReplicas": 0,
                    "maxReplicas": "[if(equals(parameters('environment'), 'prod'), 10, 2)]",
                    "rules": [
                      {
                        "name": "http-scaling",
                        "http": {
                          "metadata": {
                            "concurrentRequests": "5"
                          }
                        }
                      }
                    ]
                  }
                }
              }
            }
          ],
          "outputs": {
            "fqdn": {
              "type": "string",
              "value": "[reference(resourceId('Microsoft.App/containerApps', parameters('name')), '2024-03-01').configuration.ingress.fqdn]"
            },
            "name": {
              "type": "string",
              "value": "[parameters('name')]"
            },
            "id": {
              "type": "string",
              "value": "[resourceId('Microsoft.App/containerApps', parameters('name'))]"
            }
          }
        }
      },
      "dependsOn": [
        "acr",
        "acrPullRole",
        "appInsights",
        "blobReaderRole",
        "containerAppsEnv",
        "gameWorkerIdentity"
      ]
    }
  },
  "outputs": {
    "acrLoginServer": {
      "type": "string",
      "value": "[reference('acr').outputs.loginServer.value]"
    },
    "containerAppsEnvId": {
      "type": "string",
